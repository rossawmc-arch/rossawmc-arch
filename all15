15. Soru:

Klavyeden girilen sayı tek mi çift mi bulan programı geri dönüşümsüz metot ile yazınız.

Cevap:

void Mod(int sayi)
{
    if (sayi % 2 == 0)
    {
        MessageBox.Show("Sayı Çift");
    }
    else
    {
        MessageBox.Show("Sayı Tek");
    }
}

private void Button_Click(object sender, RoutedEventArgs e)
{
    int s = Convert.ToInt32(sayi_text.Text);
    Mod(s);
}



